---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags?: string[];
}

const { title, date, description, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Brett DeWoody`} description={description}>
  <article class="post-wrap">
    <header class="post-header">
      <div class="container">
        <a href="/blog" class="back-link">← All Posts</a>
        <h1 class="post-title gradient-text">{title}</h1>
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="tags">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
        <hr class="neon-divider" />
      </div>
    </header>

    <div class="post-body container">
      <slot />
    </div>
  </article>
</Base>

<style>
  .post-wrap {
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  .container {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-muted);
  }

  .back-link:hover {
    color: var(--color-neon-cyan);
    text-shadow: 0 0 8px var(--color-neon-cyan);
  }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .neon-divider {
    margin-bottom: 2.5rem;
  }

  .post-body {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #c8c8ee;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    color: var(--color-neon-cyan);
    margin: 2.5rem 0 1rem;
    letter-spacing: 0.06em;
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    color: var(--color-neon-magenta);
    margin: 2rem 0 0.8rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.4rem;
  }

  .post-body :global(a) {
    border-bottom: 1px solid var(--color-neon-cyan);
    padding-bottom: 1px;
  }

  .post-body :global(code) {
    font-family: "JetBrains Mono", monospace;
    background: var(--color-surface);
    color: var(--color-neon-cyan);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .post-body :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-neon-magenta);
    padding: 1.2rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border-radius: 4px;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-neon-purple);
    margin: 1.5rem 0;
    padding: 0.5rem 1.5rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .post-body :global(ul), .post-body :global(ol) {
    margin: 1rem 0 1.4rem 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-body :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin: 1rem 0;
  }
</style>
