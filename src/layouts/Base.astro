---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Brett DeWoody — AI Tooling & Engineering Leadership',
  description = 'Engineering manager and frontend architect building AI tooling and workflows that give development teams an unfair advantage.',
  ogImage = '/og.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://brettdewoody.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OG / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />


    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer-inner">
        <hr class="neon-divider" />
        <p>
          <span class="gradient-text">Brett DeWoody</span> ·
          <a href="https://github.com/brettdewoody" target="_blank" rel="noopener">GitHub</a> ·
          <a href="https://linkedin.com/in/brettdewoody" target="_blank" rel="noopener">LinkedIn</a> ·
          <a href="https://instagram.com/brettdewoody" target="_blank" rel="noopener">Instagram</a>
        </p>
        <p class="copyright">&copy; {new Date().getFullYear()}</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .footer {
    padding: 2.5rem 0 2rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .neon-divider {
    margin-bottom: 1.5rem;
  }

  .copyright {
    margin-top: 0.4rem;
    font-size: 0.7rem;
    opacity: 0.5;
  }
</style>
