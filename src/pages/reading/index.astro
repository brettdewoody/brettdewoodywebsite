---
import Base from '../../layouts/Base.astro';

interface ReadingEntry {
  date: string;
  url: string;
  title: string | null;
  note: string;
}

const res = await fetch('https://raw.githubusercontent.com/brettdewoody/reading-list/master/data.json');
const entries: ReadingEntry[] = await res.json();

function getDomain(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
}

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<Base
  title="Reading — Brett DeWoody"
  description="Links and articles I've found worth reading — engineering, leadership, product, and more."
>
  <div class="reading-listing">
    <header class="listing-header">
      <div class="container">
        <a href="/" class="back-link">← Back</a>
        <h1 class="page-title gradient-text">Reading</h1>
        <p class="page-desc">
          Things I've read and found worth saving. Engineering, leadership, product, and the
          occasional rabbit hole.
        </p>
        <hr class="neon-divider" />
      </div>
    </header>

    <div class="container">
      <ul class="entry-list">
        {entries.map(entry => (
          <li class="entry">
            <a href={entry.url} target="_blank" rel="noopener noreferrer" class="entry-link">
              <span class="entry-title">{entry.title ?? getDomain(entry.url)}</span>
              <span class="entry-domain">{getDomain(entry.url)}</span>
            </a>
            {entry.note && <p class="entry-note">{entry.note}</p>}
            <time class="entry-date" datetime={entry.date}>{formatDate(entry.date)}</time>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Base>

<style>
  .reading-listing {
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .listing-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-muted);
  }

  .back-link:hover {
    color: var(--color-neon-cyan);
    text-shadow: 0 0 8px var(--color-neon-cyan);
  }

  .page-title {
    font-size: clamp(2rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 0.8rem;
  }

  .page-desc {
    color: var(--color-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .neon-divider {
    margin-bottom: 0;
  }

  .entry-list {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .entry {
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 1rem;
    align-items: start;
  }

  .entry-link {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .entry-link:hover .entry-title {
    color: var(--color-neon-cyan);
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.4);
  }

  .entry-title {
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1.4;
    transition: color 0.2s, text-shadow 0.2s;
  }

  .entry-domain {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .entry-note {
    grid-column: 1 / -1;
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.5;
  }

  .entry-date {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 0.2rem;
  }
</style>
