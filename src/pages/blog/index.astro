---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="Writing — Brett DeWoody"
  description="Thoughts on software engineering, product craft, and building things that matter."
>
  <div class="blog-listing">
    <header class="listing-header">
      <div class="container">
        <a href="/" class="back-link">← Back</a>
        <h1 class="page-title gradient-text">Writing</h1>
        <p class="page-desc">
          Thoughts on engineering craft, products, and whatever's on my mind.
          I mostly write code — and these days, prompts. Prose comes along occasionally.
        </p>
        <hr class="neon-divider" />
      </div>
    </header>

    <div class="container">
      {posts.length === 0 ? (
        <p class="empty">Nothing published yet — check back soon.</p>
      ) : (
        <div class="posts-grid">
          {posts.map(post => <BlogCard post={post} />)}
        </div>
      )}
    </div>
  </div>
</Base>

<style>
  .blog-listing {
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .listing-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-muted);
  }

  .back-link:hover {
    color: var(--color-neon-cyan);
    text-shadow: 0 0 8px var(--color-neon-cyan);
  }

  .page-title {
    font-size: clamp(2rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 0.8rem;
  }

  .page-desc {
    color: var(--color-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .neon-divider {
    margin-bottom: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .empty {
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    margin-top: 2rem;
  }
</style>
