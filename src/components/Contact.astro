---
const socialLinks = [
  {
    label: 'LinkedIn',
    handle: 'in/brettdewoody',
    url: 'https://linkedin.com/in/brettdewoody',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    color: 'magenta',
  },
  {
    label: 'GitHub',
    handle: '@brettdewoody',
    url: 'https://github.com/brettdewoody',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
    color: 'cyan',
  },
  {
    label: 'Instagram',
    handle: '@brettdewoody',
    url: 'https://instagram.com/brettdewoody',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
    color: 'purple',
  },
  {
    label: 'Strava',
    handle: '/brettdewoody',
    url: 'https://www.strava.com/athletes/970237',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>`,
    color: 'magenta',
  },
];
---

<section class="contact" id="contact">
  <div class="container">
    <h2 class="section-heading neon-text-cyan">Contact</h2>

    <div class="contact-grid">
      <div class="contact-text">
        <p class="contact-headline gradient-text">
          Say hello.
        </p>
        <p>
          Whether you want to talk engineering, have a question about something
          I've built, or just want to connect — I'm always happy to hear from people
          doing interesting work.
        </p>
        <p>
          The best way to reach me is email. I'm also responsive on LinkedIn.
        </p>
      </div>

      <div class="contact-links">
        {socialLinks.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class:list={['contact-card neon-card', `contact-card-${link.color}`]}
          >
            <span class="contact-icon" set:html={link.icon}></span>
            <div>
              <span class="contact-label">{link.label}</span>
              <span class="contact-handle">{link.handle}</span>
            </div>
            <svg class="contact-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}

        <!-- Email: href and handle set by JS to keep address out of static HTML -->
        <a
          id="email-link"
          data-e="aGVsbG9AYnJldHRkZXdvb2R5LmNvbQ=="
          class="contact-card neon-card contact-card-cyan"
        >
          <span class="contact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
          </span>
          <div>
            <span class="contact-label">Email</span>
            <span class="contact-handle" id="email-handle">—</span>
          </div>
          <svg class="contact-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('email-link') as HTMLAnchorElement;
  if (el) {
    const addr = atob(el.dataset.e!);
    el.href = 'mailto:' + addr;
    const handle = document.getElementById('email-handle');
    if (handle) handle.textContent = addr;
  }
</script>

<style>
  .contact {
    background: var(--color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 3rem;
    align-items: start;
  }

  .contact-headline {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }

  .contact-text p {
    color: #a0a0c8;
    font-size: 1rem;
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    color: var(--color-text) !important;
    text-shadow: none !important;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }

  .contact-card:hover {
    transform: translateX(4px);
  }

  .contact-card-cyan:hover {
    border-color: var(--color-neon-cyan);
    box-shadow: 0 0 12px rgba(0, 240, 255, 0.2);
  }

  .contact-card-magenta:hover {
    border-color: var(--color-neon-magenta);
    box-shadow: 0 0 12px rgba(255, 0, 255, 0.2);
  }

  .contact-card-purple:hover {
    border-color: var(--color-neon-purple);
    box-shadow: 0 0 12px rgba(191, 0, 255, 0.2);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .contact-card-cyan .contact-icon  { color: var(--color-neon-cyan); }
  .contact-card-magenta .contact-icon { color: var(--color-neon-magenta); }
  .contact-card-purple .contact-icon  { color: var(--color-neon-purple); }

  .contact-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .contact-handle {
    display: block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.15rem;
  }

  .contact-arrow {
    margin-left: auto;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }

  .contact-card:hover .contact-arrow {
    transform: translateX(4px);
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
