---
import { Image } from 'astro:assets';
import headshot from '../../public/brett-dewoody.jpg';
---

<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <h2 class="section-heading neon-text-cyan">About</h2>

        <p>
          I'm an engineering manager and frontend architect based in
          <strong>Aberfeldy, Scotland</strong> (originally from the US).
          At <a href="https://legatics.com" target="_blank" rel="noopener">Legatics</a> I
          lead engineering on transaction management software — building the team, the
          process, and the product in equal measure.
        </p>

        <p>
          My background is deeply technical: I've spent years as a
          <strong>lead frontend engineer and architect</strong>, which means I bring
          hands-on craft to the management role. Lately that's meant going deep on
          <strong>AI tooling and process</strong> — building the systems, workflows,
          and integrations that let engineering teams move faster without cutting corners.
          Not AI for its own sake, but AI as genuine developer leverage.
        </p>

        <p>
          Outside of work: cycling (Highland Perthshire is an absurd place to ride),
          music, and volunteering with
          <a href="https://draftandflow.com" target="_blank" rel="noopener">Draft &amp; Flow</a>
          and
          <a href="https://www.highlandperthshirecycling.co.uk" target="_blank" rel="noopener">Highland Perthshire Cycling</a>.
        </p>

        <div class="about-links">
          <a href="https://linkedin.com/in/brettdewoody" target="_blank" rel="noopener" class="btn-neon btn-neon-magenta">
            LinkedIn
          </a>
          <a id="about-email-link" data-e="aGVsbG9AYnJldHRkZXdvb2R5LmNvbQ==" class="btn-neon">
            Email
          </a>
        </div>

        <script>
          const el = document.getElementById('about-email-link') as HTMLAnchorElement;
          if (el) el.href = 'mailto:' + atob(el.dataset.e!);
        </script>
      </div>

      <aside class="about-stats">
        <div class="headshot-wrap">
          <Image
            src={headshot}
            alt="Brett DeWoody"
            class="headshot"
            width={280}
            height={280}
            loading="lazy"
            format="webp"
            quality={85}
          />
        </div>
        <div class="stat-card neon-card">
          <span class="stat-num neon-text-magenta">20+</span>
          <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-card neon-card">
          <span class="stat-num neon-text-cyan">Eng Leadership</span>
          <span class="stat-label">AI-First Software Dev</span>
        </div>
        <div class="stat-card neon-card">
          <span class="stat-num neon-text-purple">Scotland</span>
          <span class="stat-label">Remote / Hybrid</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    color: #b0b0d8;
    margin-bottom: 1.2rem;
    font-size: 1.1rem;
  }

  .about-text p a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-text strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .about-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .headshot-wrap {
    position: relative;
  }

  .headshot-wrap::after {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--color-neon-magenta), var(--color-neon-cyan));
    z-index: 0;
    opacity: 0.7;
  }

  .headshot {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    filter: grayscale(20%);
    transition: filter 0.3s;
  }

  .headshot-wrap:hover .headshot {
    filter: grayscale(0%);
  }

  .stat-card {
    padding: 1.4rem 1.2rem;
    text-align: center;
  }

  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-stats {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .stat-card {
      flex: 1;
      min-width: 140px;
    }
  }
</style>
