---

<section class="experience" id="experience">
  <div class="container">
    <h2 class="section-heading">Experience</h2>

    <div class="timeline">
      {jobs.map((job, i) => (
        <div class:list={['timeline-item', { 'timeline-item--community': job.community }]} style={`animation-delay: ${i * 0.1}s`}>
          <div class:list={['timeline-dot', { 'timeline-dot--community': job.community }]}></div>
          <div class:list={['timeline-card', job.community ? 'community-card' : 'neon-card']}>
            {job.community && (
              <span class="community-badge">Community</span>
            )}
            <div class="job-header">
              <div>
                <h3 class="job-title">{job.title}</h3>
                {job.companyUrl !== '#' ? (
                  <a href={job.companyUrl} target="_blank" rel="noopener" class:list={['job-company', { 'job-company--community': job.community }]}>
                    {job.company}
                  </a>
                ) : (
                  <span class="job-company no-link">{job.company}</span>
                )}
              </div>
              <div class="job-meta">
                <span class="job-period">{job.period}</span>
                <span class="job-location">{job.location}</span>
              </div>
            </div>

            <ul class="job-highlights">
              {job.highlights.map(h => <li>{h}</li>)}
            </ul>

            <div class="job-tags">
              {job.tags.map((tag, j) => (
                <span class:list={['tag', job.community ? 'tag-purple' : j % 3 === 1 ? 'tag-magenta' : j % 3 === 2 ? 'tag-purple' : '']}>
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .timeline {
    position: relative;
    margin-top: 3rem;
    padding-left: 2rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-neon-magenta),
      var(--color-neon-cyan),
      var(--color-neon-purple),
      transparent
    );
    box-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2.5rem;
  }

  /* ─── Community variant ─── */
  .timeline-item--community {
    margin-bottom: 2rem;
  }

  .timeline-dot {
    position: absolute;
    left: calc(-2.45rem + 2px);
    top: 1.5rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-neon-magenta);
    box-shadow: 0 0 0 3px var(--color-bg), 0 0 12px var(--color-neon-magenta);
  }

  .timeline-dot--community {
    background: var(--color-neon-purple);
    box-shadow: 0 0 0 3px var(--color-bg), 0 0 10px var(--color-neon-purple);
    width: 10px;
    height: 10px;
    top: 1.3rem;
    left: calc(-2.4rem + 2px);
  }

  /* ─── Professional card ─── */
  .timeline-card {
    padding: 1.6rem 1.8rem;
  }

  /* ─── Community card ─── */
  .community-card {
    background: transparent;
    border: 1px dashed rgba(191, 0, 255, 0.35);
    border-radius: 4px;
    padding: 1.1rem 1.4rem;
    transition: border-color 0.3s;
  }

  .community-card:hover {
    border-color: var(--color-neon-purple);
    box-shadow: 0 0 10px rgba(191, 0, 255, 0.1);
  }

  .community-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-neon-purple);
    border: 1px solid rgba(191, 0, 255, 0.4);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    margin-bottom: 0.7rem;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .job-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.04em;
    margin: 0 0 0.2rem;
  }

  .timeline-item--community .job-title {
    font-size: 0.95rem;
    color: #b0b0d0;
  }

  .job-company {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  a.job-company {
    color: var(--color-neon-cyan) !important;
    text-shadow: none !important;
  }

  a.job-company:hover {
    text-shadow: 0 0 8px var(--color-neon-cyan) !important;
  }

  a.job-company--community {
    color: var(--color-neon-purple) !important;
  }

  a.job-company--community:hover {
    text-shadow: 0 0 8px var(--color-neon-purple) !important;
  }

  .no-link {
    color: var(--color-muted);
  }

  .job-meta {
    text-align: right;
    flex-shrink: 0;
  }

  .job-period {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .job-location {
    display: block;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-top: 0.2rem;
    opacity: 0.7;
  }

  .job-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 1.2rem;
  }

  .job-highlights li {
    color: #a0a0c8;
    font-size: 0.95rem;
    padding: 0.3rem 0 0.3rem 1.2rem;
    position: relative;
    line-height: 1.6;
  }

  .timeline-item--community .job-highlights li {
    font-size: 0.88rem;
    color: #7878a8;
  }

  .job-highlights li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--color-neon-magenta);
    font-size: 1rem;
  }

  .timeline-item--community .job-highlights li::before {
    color: var(--color-neon-purple);
  }

  .job-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 600px) {
    .job-header {
      flex-direction: column;
    }

    .job-meta {
      text-align: left;
    }
  }
</style>
