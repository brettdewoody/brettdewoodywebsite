---
interface Props {
  hasPosts?: boolean;
}
const { hasPosts = false } = Astro.props;
---

<section class="hero" id="hero">
  <!-- Synthwave grid -->
  <div class="grid-container" aria-hidden="true">
    <div class="star-layer star-small"></div>
    <div class="star-layer star-medium"></div>
    <div class="star-layer star-bright"></div>
    <div class="grid-horizon"></div>
    <canvas class="grid-canvas" aria-hidden="true"></canvas>
  </div>

  <!-- Glow orbs -->
  <div class="orb orb-left" aria-hidden="true"></div>
  <div class="orb orb-right" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="hero-name">
      <span class="name-line">Brett</span>
      <span class="name-line neon-text-magenta glitch" data-text="DeWoody">DeWoody</span>
    </h1>

    <p class="hero-title">
      <span class="gradient-text">Engineering<br/>Leadership</span>
      <span class="hero-title-sep" aria-hidden="true">·</span>
      <span class="gradient-text">AI-First Software Development</span>
    </p>

    <p class="hero-tagline">
      20+ years building and leading engineering teams, shipping products,
      and crafting <span class="neon-text-cyan">AI tooling and workflows</span>
      that help engineering teams do more.<br />
      Scotland-based, US-born.
      <span class="neon-text-magenta">Frontend architect</span> turned engineering leader.
    </p>

    <div class="hero-cta">
      <a href="/#contact" class="btn-neon btn-neon-magenta">Get in touch</a>
      {hasPosts && <a href="/blog" class="btn-neon">Writings</a>}
    </div>
  </div>

  <!-- Scroll indicator lives outside hero-content so it anchors to the section bottom -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 64px 1.5rem 80px;
  }

  /* ─── Stars ─── */
  .star-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    border-radius: 50%;
    background: transparent;
  }

  .star-small {
    box-shadow:
      83px 48px rgba(200,220,255,0.45), 197px 112px rgba(200,220,255,0.35),
      341px 67px rgba(200,220,255,0.50), 488px 143px rgba(200,220,255,0.40),
      612px 29px rgba(200,220,255,0.45), 734px 95px rgba(200,220,255,0.35),
      876px 55px rgba(200,220,255,0.50), 1023px 130px rgba(200,220,255,0.40),
      1158px 72px rgba(200,220,255,0.45), 1290px 108px rgba(200,220,255,0.35),
      143px 218px rgba(200,220,255,0.40), 265px 285px rgba(200,220,255,0.35),
      412px 198px rgba(200,220,255,0.45), 557px 252px rgba(200,220,255,0.40),
      698px 312px rgba(200,220,255,0.35), 819px 228px rgba(200,220,255,0.45),
      967px 268px rgba(200,220,255,0.40), 1094px 195px rgba(200,220,255,0.35),
      1237px 242px rgba(200,220,255,0.45), 1368px 278px rgba(200,220,255,0.40),
      58px 338px rgba(200,220,255,0.30), 224px 372px rgba(200,220,255,0.35),
      389px 395px rgba(200,220,255,0.30), 531px 418px rgba(200,220,255,0.25),
      674px 355px rgba(200,220,255,0.30), 802px 442px rgba(200,220,255,0.25),
      944px 368px rgba(200,220,255,0.30), 1112px 405px rgba(200,220,255,0.25),
      1265px 385px rgba(200,220,255,0.30), 1410px 422px rgba(200,220,255,0.25);
    animation: star-twinkle 5s ease-in-out infinite alternate;
  }

  .star-medium {
    width: 2px;
    height: 2px;
    box-shadow:
      162px 78px rgba(220,235,255,0.55), 438px 34px rgba(220,235,255,0.60),
      715px 88px rgba(220,235,255,0.55), 952px 44px rgba(220,235,255,0.60),
      1195px 91px rgba(220,235,255,0.55), 308px 178px rgba(220,235,255,0.50),
      584px 158px rgba(220,235,255,0.55), 841px 202px rgba(220,235,255,0.50),
      1072px 168px rgba(220,235,255,0.55), 1334px 185px rgba(220,235,255,0.50),
      98px 295px rgba(220,235,255,0.45), 472px 318px rgba(220,235,255,0.40),
      758px 288px rgba(220,235,255,0.45), 1028px 305px rgba(220,235,255,0.40);
    animation: star-twinkle 7s ease-in-out infinite alternate;
    animation-delay: -2s;
  }

  .star-bright {
    width: 2px;
    height: 2px;
    box-shadow:
      280px 62px 3px rgba(180,240,255,0.85), 640px 118px 3px rgba(180,240,255,0.80),
      920px 55px 3px rgba(180,240,255,0.85), 1180px 142px 3px rgba(180,240,255,0.80),
      450px 245px 2px rgba(180,240,255,0.75), 800px 198px 2px rgba(180,240,255,0.80),
      1050px 265px 2px rgba(180,240,255,0.75), 180px 162px 2px rgba(180,240,255,0.70);
    animation: star-twinkle 3.5s ease-in-out infinite alternate;
    animation-delay: -1s;
  }

  @keyframes star-twinkle {
    0%   { opacity: 0.6; }
    50%  { opacity: 1; }
    100% { opacity: 0.7; }
  }

  /* ─── Synthwave grid ─── */
  .grid-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .grid-horizon {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    top: 50%;
    background: linear-gradient(
      to bottom,
      rgba(255, 0, 255, 0.05) 0%,
      transparent 100%
    );
  }

  .grid-canvas {
    position: absolute;
    bottom: 0;
    left: -20%;
    width: 140%;
    height: 55%;
    transform: perspective(500px) rotateX(60deg);
    transform-origin: center top;
  }

  /* ─── Glow orbs ─── */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    opacity: 0.35;
  }

  .orb-left {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #bf00ff 0%, transparent 70%);
    top: 10%;
    left: -10%;
  }

  .orb-right {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #ff00ff 0%, transparent 70%);
    bottom: 5%;
    right: -5%;
  }

  /* ─── Content ─── */
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 780px;
    animation: fade-up 0.8s ease both;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
  }

  .name-line {
    display: block;
  }

  .name-line:first-child {
    color: #a8d8ff;
    text-shadow: 0 0 40px rgba(0, 240, 255, 0.2);
  }

  /* Glitch effect */
  .glitch {
    position: relative;
    color: var(--color-neon-magenta);
    text-shadow:
      0 0 10px var(--color-neon-magenta),
      0 0 30px var(--color-neon-magenta);
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    color: var(--color-neon-magenta);
  }

  .glitch::before {
    color: var(--color-neon-cyan);
    animation: glitch 6s infinite;
    animation-delay: 0.5s;
  }

  .glitch::after {
    color: #ff2d78;
    animation: glitch 6s infinite;
    animation-delay: 1s;
    opacity: 0.6;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(0.65rem, 1.6vw, 1rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 1.8rem 0 1.6rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-title span:first-child { text-align: right; }
  .hero-title span:last-child  { text-align: left; }

  .hero-title-sep {
    color: var(--color-neon-magenta);
    text-shadow: 0 0 8px var(--color-neon-magenta);
    letter-spacing: 0;
    font-size: 1.4em;
    line-height: 1;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: #a0a0c8;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ─── Scroll indicator — anchored to section, not content ─── */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-muted), transparent);
    animation: scroll-fade 1.5s ease-in-out infinite;
  }

  @keyframes scroll-fade {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 1; }
  }
</style>

<script>
  const canvas = document.querySelector('.grid-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const CELL = 80;
    const RIPPLE_AMP = 6;
    const RIPPLE_FREQ = 0.007;
    const RIPPLE_SPEED = 1.2;
    const SCROLL_PX_PER_FRAME = 80 / (3 * 60); // match original 3s per cell

    let scrollOffset = 0;
    let time = 0;
    let raf: number;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function draw() {
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);

      scrollOffset = (scrollOffset + SCROLL_PX_PER_FRAME) % CELL;
      time += 0.012;

      ctx.lineWidth = 1;

      // Gradient stroke — transparent at top, visible in middle, fades at bottom
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0,    'rgba(0, 240, 255, 0)');
      grad.addColorStop(0.25, 'rgba(0, 240, 255, 0)');
      grad.addColorStop(0.55, 'rgba(0, 240, 255, 0.16)');
      grad.addColorStop(0.80, 'rgba(0, 240, 255, 0.18)');
      grad.addColorStop(0.93, 'rgba(0, 240, 255, 0.08)');
      grad.addColorStop(1,    'rgba(0, 240, 255, 0)');
      ctx.strokeStyle = grad;

      // Vertical lines — X ripple (left/right wobble)
      for (let x = 0; x <= w; x += CELL) {
        ctx.beginPath();
        for (let y = 0; y <= h; y += 4) {
          const dx = x - w / 2;
          const r = Math.sqrt(dx * dx + y * y);
          const rippleX = Math.cos(r * RIPPLE_FREQ - time * RIPPLE_SPEED) * RIPPLE_AMP * 0.6;
          const px = x + rippleX;
          y === 0 ? ctx.moveTo(px, y) : ctx.lineTo(px, y);
        }
        ctx.stroke();
      }

      // Horizontal lines — Y ripple (up/down) + X ripple (left/right)
      for (let y = -CELL + scrollOffset; y < h + CELL; y += CELL) {
        ctx.beginPath();
        for (let x = 0; x <= w; x += 4) {
          const dx = x - w / 2;
          const r = Math.sqrt(dx * dx + y * y);
          const wave = r * RIPPLE_FREQ - time * RIPPLE_SPEED;
          const rippleY = Math.sin(wave) * RIPPLE_AMP;
          const rippleX = Math.cos(wave) * RIPPLE_AMP * 0.6;
          x === 0 ? ctx.moveTo(x + rippleX, y + rippleY) : ctx.lineTo(x + rippleX, y + rippleY);
        }
        ctx.stroke();
      }

      raf = requestAnimationFrame(draw);
    }

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!prefersReduced.matches) {
      resize();
      window.addEventListener('resize', resize);
      draw();
    }
  }
</script>
