---
const projects = [
  {
    name: 'Reading List',
    tagline: 'Curated dev articles with personal commentary.',
    description:
      'A curated collection of development-related articles, annotated with personal insights. A living reference for the things worth reading twice.',
    url: 'https://github.com/brettdewoody/reading-list',
    repo: 'https://github.com/brettdewoody/reading-list',
    tags: ['Curation', 'Development'],
    featured: false,
  },
  {
    name: 'Binary Heap Visualizer',
    tagline: 'Visual min-heap constructor in JavaScript.',
    description:
      'An interactive visualizer for building and exploring a binary min-heap. Built to make an abstract data structure tangible — the kind of project that teaches you more than any tutorial.',
    url: 'https://github.com/brettdewoody/binary-heap-visualizer',
    repo: 'https://github.com/brettdewoody/binary-heap-visualizer',
    tags: ['JavaScript', 'Data Structures', 'Visualisation'],
    featured: true,
  },
  {
    name: 'PunkAPI JavaScript Wrapper',
    tagline: 'Clean JS wrapper for BrewDog\'s Punk API V2.',
    description:
      'A well-documented JavaScript wrapper for BrewDog\'s Punk API. Simple interface, clean abstractions — the way API wrappers should be.',
    url: 'https://github.com/brettdewoody/punkapi-javascript-wrapper',
    repo: 'https://github.com/brettdewoody/punkapi-javascript-wrapper',
    tags: ['JavaScript', 'API', 'Open Source'],
    featured: true,
  },
  {
    name: 'Top X of Y',
    tagline: 'Photo collage generator for yearly favourites.',
    description:
      'A tool for generating photo collages from your yearly favourites. Scratches a specific itch in a satisfying way.',
    url: 'https://github.com/brettdewoody/top-x-of-y',
    repo: 'https://github.com/brettdewoody/top-x-of-y',
    tags: ['HTML', 'JavaScript'],
    featured: false,
  },
];
---

<section class="projects" id="projects">
  <div class="container">
    <h2 class="section-heading">Projects</h2>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class:list={['project-card neon-card', { featured: project.featured }]}>
          {project.featured && (
            <span class="featured-badge">Featured</span>
          )}

          <h3 class="project-name">
            <a href={project.url} target="_blank" rel="noopener">{project.name}</a>
          </h3>
          <p class="project-tagline">{project.tagline}</p>
          <p class="project-desc">{project.description}</p>

          <div class="project-footer">
            <div class="project-tags">
              {project.tags.map((tag, j) => (
                <span class:list={['tag', j % 2 === 0 ? '' : 'tag-magenta']}>
                  {tag}
                </span>
              ))}
            </div>
            <div class="project-links">
              {project.repo !== project.url && (
                <a href={project.repo} target="_blank" rel="noopener" class="icon-link" title="Source code">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                </a>
              )}
              <a href={project.url} target="_blank" rel="noopener" class="icon-link" title="View project">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .project-card {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .project-card.featured {
    border-color: rgba(255, 0, 255, 0.3);
  }

  .project-card.featured:hover {
    border-color: var(--color-neon-magenta);
    box-shadow:
      0 0 8px rgba(255, 0, 255, 0.2),
      0 0 24px rgba(255, 0, 255, 0.1);
  }

  .featured-badge {
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-neon-magenta);
    border: 1px solid var(--color-neon-magenta);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    align-self: flex-start;
    margin-bottom: 0.8rem;
  }

  .project-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    letter-spacing: 0.04em;
  }

  .project-name a {
    color: var(--color-text) !important;
    text-shadow: none !important;
    transition: color 0.2s;
  }

  .project-name a:hover {
    color: var(--color-neon-cyan) !important;
  }

  .project-tagline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-neon-cyan);
    margin: 0 0 0.8rem;
    text-transform: uppercase;
  }

  .project-desc {
    color: #a0a0c8;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.2rem;
    gap: 0.8rem;
  }

  .project-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .project-links {
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .icon-link {
    color: var(--color-muted) !important;
    transition: color 0.2s, text-shadow 0.2s !important;
    display: flex;
    align-items: center;
  }

  .icon-link:hover {
    color: var(--color-neon-cyan) !important;
    text-shadow: none !important;
  }
</style>
